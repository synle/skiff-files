{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for the main window.",
  "windows": ["main", "main-*", "preview-*"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "shell:allow-open",
    "drag:default",
    "dialog:allow-open"
  ]
}
