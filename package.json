{
  "name": "skiff-files",
  "version": "0.1.1",
  "description": "Skiff Files — fast cross-platform file explorer with FTP / SFTP / SMB and a smart-sync engine. Tauri v2 + React 19.",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run --exclude src/App.test.tsx",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --exclude src/App.test.tsx",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@types/diff": "^7.0.2",
    "diff": "^9.0.0",
    "i18next": "^26.0.10",
    "marked": "^18.0.4",
    "prismjs": "^1.30.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.7",
    "react-router": "^7.14.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.2",
    "typescript": "~5.8",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  }
}
